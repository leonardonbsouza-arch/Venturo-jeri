{
  "version": 2,
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/venturoexperience/?",
      "dest": "/instagram.html"
    },
    {
      "handle": "filesystem"
    }
  ]
}
